" Numbering
set number
set relativenumber

" Typing
filetype plugin indent on
set expandtab
set shiftwidth=4
set softtabstop=4
set tabstop=4
set smartindent
set backspace=indent,eol,start
set wrap
set colorcolumn=80

" Highlighting
syntax on
set cursorcolumn
set cursorline
set hlsearch
set incsearch

" Clipboard
set clipboard=unnamedplus
